# Key only — NOT the full omdbapi.com URL (get one at https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=your_omdb_api_key_here

GEMINI_API_KEY=your_gemini_api_key_here
# Optional override (defaults try gemini-2.0-flash, then newer fallbacks)
# GEMINI_MODEL=gemini-2.0-flash

SKIP_VIDEO_RENDER=true

# Optional Edge TTS voice (free, no extra API key)
# TTS_VOICE=en-US-AndrewNeural
